  <script>
    const hdr = document.getElementById('hdr');
    const onScroll = () => hdr.classList.toggle('scrolled', window.scrollY > 60);
    onScroll(); window.addEventListener('scroll', onScroll, { passive: true });

    const mp = document.getElementById('mpanel');
    document.getElementById('burger').addEventListener('click', () => mp.classList.add('open'));
    document.getElementById('mclose').addEventListener('click', () => mp.classList.remove('open'));
    mp.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mp.classList.remove('open')));

    function slideshow(slides, dots, interval) {
      let i = 0, timer;
      const reduce = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
      const go = n => {
        slides[i].classList.remove('active'); if (dots) dots[i].classList.remove('active');
        i = (n + slides.length) % slides.length;
        slides[i].classList.add('active'); if (dots) dots[i].classList.add('active');
      };
      const start = () => { if (!reduce) timer = setInterval(() => go(i + 1), interval); };
      if (dots) { dots.forEach(d => d.addEventListener('click', () => { clearInterval(timer); go(+d.dataset.i); start(); })); }
      start();
    }
    slideshow(document.querySelectorAll('.phero-slide'), Array.from(document.querySelectorAll('#pheroDots .dot')), 6000);
    slideshow(document.querySelectorAll('.cta-slide'), null, 6000);

    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
