<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us — Praniflex | Hotel Linen Manufacturers &amp; Suppliers, Karur India</title>
  <meta name="description"
    content="Established in 1985, Praniflex is a leading manufacturer and supplier of luxury hotel &amp; hospital linen in India — woven on Swiss Sulzer and Italian Vamatex looms in Karur." />
  <link rel="icon" type="image/png"
    href="data:image/png;base64," />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Poppins:wght@200;300;400;500;600;700&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --navy: #122C47;
      --navy-2: #1A4972;
      --lime: #A8D242;
      --lime-deep: #6f9326;
      --gold: #C2A24E;
      --gold-soft: #d8be84;
      --paper: #F7F3EA;
      --paper-2: #FCFAF4;
      --ink: #2b3640;
      --muted: #5e6b73;
      --line: rgba(18, 44, 71, .14);
      --shadow: 0 24px 60px -28px rgba(18, 44, 71, .45);
      --maxw: 1240px;
      --ease: cubic-bezier(.16, 1, .3, 1);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    @media (prefers-reduced-motion:reduce) {
      html {
        scroll-behavior: auto;
      }
    }

    body {
      margin: 0;
      font-family: 'Poppins', system-ui, sans-serif;
      color: var(--ink);
      background: var(--paper);
      font-weight: 300;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    h1,
    h2,
    h3,
    h4 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      margin: 0;
      line-height: 1.08;
      letter-spacing: .005em;
    }

    p {
      margin: 0;
    }

    .wrap {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 0 32px;
    }

    .eyebrow {
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      font-size: .7rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--lime-deep);
      display: inline-flex;
      align-items: center;
      gap: .7em;
    }

    .eyebrow::before {
      content: "";
      width: 30px;
      height: 1px;
      background: var(--gold);
      display: inline-block;
    }

    .eyebrow.center {
      justify-content: center;
    }

    .eyebrow.light {
      color: var(--lime);
    }

    .eyebrow.light::before {
      background: var(--gold-soft);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: .7em;
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      font-size: .76rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: 15px 30px;
      border-radius: 2px;
      cursor: pointer;
      border: 1px solid transparent;
      transition: transform .5s var(--ease), background .4s var(--ease), color .4s var(--ease), box-shadow .4s var(--ease);
    }

    .btn .arw {
      transition: transform .5s var(--ease);
    }

    .btn:hover .arw {
      transform: translateX(5px);
    }

    .btn-gold {
      background: var(--gold);
      color: var(--navy);
    }

    .btn-gold:hover {
      background: var(--lime);
      box-shadow: 0 16px 30px -16px rgba(168, 210, 66, .7);
      transform: translateY(-2px);
    }

    .btn-ghost {
      border-color: rgba(255, 255, 255, .55);
      color: #fff;
    }

    .btn-ghost:hover {
      background: #fff;
      color: var(--navy);
      transform: translateY(-2px);
    }

    .btn-navy {
      background: var(--navy);
      color: #fff;
    }

    .btn-navy:hover {
      background: var(--navy-2);
      transform: translateY(-2px);
    }

    .btn-outline {
      border-color: var(--navy);
      color: var(--navy);
    }

    .btn-outline:hover {
      background: var(--navy);
      color: #fff;
      transform: translateY(-2px);
    }

    /* ---------- HEADER ---------- */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      transition: background .5s var(--ease), box-shadow .5s var(--ease), padding .5s var(--ease);
      padding: 10px 0;
    }

    header.scrolled {
      background: rgba(247, 243, 234, .94);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 var(--line);
      padding: 2px 0;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand img {
      height: 54px;
      width: auto;
      transition: height .4s var(--ease);
    }

    header.scrolled .brand img {
      height: 46px;
    }

    .brand .logo-light {
      display: block;
    }

    .brand .logo-dark {
      display: none;
    }

    header.scrolled .brand .logo-light {
      display: none;
    }

    header.scrolled .brand .logo-dark {
      display: block;
    }

    .menu {
      display: flex;
      align-items: center;
      gap: 6px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .menu>li {
      position: relative;
    }

    .menu>li>a {
      font-family: 'Poppins', sans-serif;
      font-weight: 400;
      font-size: .8rem;
      letter-spacing: .04em;
      color: #fff;
      padding: 12px 16px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 2px;
      transition: color .3s;
      position: relative;
    }

    header.scrolled .menu>li>a {
      color: var(--navy);
    }

    .menu>li>a.active {
      color: var(--lime);
    }

    header.scrolled .menu>li>a.active {
      color: var(--lime-deep);
    }

    .menu>li>a::after {
      content: "";
      position: absolute;
      left: 16px;
      right: 16px;
      bottom: 7px;
      height: 1px;
      background: var(--lime);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .4s var(--ease);
    }

    .menu>li>a:hover::after,
    .menu>li>a.active::after {
      transform: scaleX(1);
    }

    .menu>li>a .caret {
      width: 8px;
      height: 8px;
      border-right: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;
      transform: rotate(45deg) translateY(-2px);
      opacity: .7;
    }

    .dropdown {
      position: absolute;
      top: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--paper-2);
      min-width: 210px;
      padding: 10px;
      border-radius: 4px;
      box-shadow: var(--shadow);
      border: 1px solid var(--line);
      opacity: 0;
      visibility: hidden;
      transition: all .35s var(--ease);
      list-style: none;
      margin: 0;
    }

    .menu>li:hover .dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .dropdown li a {
      display: block;
      padding: 10px 14px;
      font-size: .82rem;
      color: var(--navy);
      border-radius: 3px;
      transition: .25s;
    }

    .dropdown li a:hover {
      background: var(--navy);
      color: #fff;
      padding-left: 20px;
    }

    .nav-cta {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .nav-phone {
      font-family: 'Poppins';
      font-size: .8rem;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 8px;
      letter-spacing: .02em;
    }

    header.scrolled .nav-phone {
      color: var(--navy);
    }

    .nav-phone svg {
      width: 15px;
      height: 15px;
    }

    .burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 0;
      cursor: pointer;
      padding: 8px;
    }

    .burger span {
      width: 26px;
      height: 2px;
      background: #fff;
      transition: .3s;
    }

    header.scrolled .burger span {
      background: var(--navy);
    }

    /* ---------- PAGE HERO ---------- */
    .phero {
      position: relative;
      height: 74vh;
      min-height: 520px;
      overflow: hidden;
      background: var(--navy);
    }

    .phero-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1.6s var(--ease);
    }

    .phero-slide.active {
      opacity: 1;
    }

    .phero-slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.08);
      transition: transform 8s linear;
    }

    .phero-slide.active img {
      transform: scale(1);
    }

    .phero::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 2;
      background: linear-gradient(180deg, rgba(12, 28, 46, .55), rgba(12, 28, 46, .45) 45%, rgba(12, 28, 46, .82));
    }

    .phero-inner {
      position: relative;
      z-index: 3;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #fff;
      padding-top: 60px;
    }

    .phero-inner .eyebrow {
      margin-bottom: 18px;
      animation: rise .9s .2s var(--ease) both;
    }

    .phero h1 {
      font-size: clamp(3rem, 7vw, 6rem);
      font-weight: 600;
      animation: rise .9s .32s var(--ease) both;
    }

    .phero h1 em {
      font-style: italic;
      color: var(--lime);
    }

    .crumb {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
      font-family: 'Poppins';
      font-size: .8rem;
      letter-spacing: .08em;
      color: rgba(255, 255, 255, .85);
      animation: rise .9s .46s var(--ease) both;
    }

    .crumb a:hover {
      color: var(--lime);
    }

    .crumb .sep {
      width: 5px;
      height: 5px;
      border-right: 1.5px solid var(--gold-soft);
      border-top: 1.5px solid var(--gold-soft);
      transform: rotate(45deg);
    }

    .crumb .cur {
      color: var(--lime);
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(26px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .phero-dots {
      position: absolute;
      z-index: 4;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 12px;
    }

    .dot {
      width: 34px;
      height: 3px;
      background: rgba(255, 255, 255, .3);
      border: 0;
      cursor: pointer;
      padding: 0;
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    }

    .dot::after {
      content: "";
      position: absolute;
      inset: 0;
      background: var(--lime);
      transform: scaleX(0);
      transform-origin: left;
    }

    .dot.active::after {
      animation: fill 6s linear forwards;
    }

    @keyframes fill {
      from {
        transform: scaleX(0);
      }

      to {
        transform: scaleX(1);
      }
    }

    section {
      position: relative;
    }

    .pad {
      padding: 120px 0;
    }

    .pad-sm {
      padding: 84px 0;
    }

    .reveal {
      opacity: 0;
      transform: translateY(34px);
      transition: opacity 1s var(--ease), transform 1s var(--ease);
    }

    .reveal.in {
      opacity: 1;
      transform: none;
    }

    .reveal.d1 {
      transition-delay: .12s;
    }

    .reveal.d2 {
      transition-delay: .24s;
    }

    .lead {
      font-size: clamp(2rem, 4vw, 3.1rem);
      font-weight: 600;
      color: var(--navy);
      line-height: 1.12;
    }

    .lead em {
      font-style: italic;
      color: var(--gold);
    }

    .body-copy {
      color: var(--muted);
      font-size: 1.02rem;
      margin-top: 22px;
    }

    .body-copy+.body-copy {
      margin-top: 16px;
    }

    /* ---------- SUPPLIERS ---------- */
    .suppliers {
      background: var(--paper);
    }

    .sup-grid {
      display: grid;
      grid-template-columns: 1fr 1.05fr;
      gap: 74px;
      align-items: center;
    }

    .sup-figure {
      position: relative;
    }

    .sup-figure img {
      border-radius: 6px;
      box-shadow: var(--shadow);
      position: relative;
      z-index: 2;
    }

    .sup-figure::before {
      content: "";
      position: absolute;
      left: -22px;
      top: -22px;
      width: 130px;
      height: 130px;
      border-top: 2px solid var(--gold);
      border-left: 2px solid var(--gold);
      z-index: 1;
    }

    .sup-figure::after {
      content: "";
      position: absolute;
      right: -22px;
      bottom: -22px;
      width: 130px;
      height: 130px;
      border-bottom: 2px solid var(--lime);
      border-right: 2px solid var(--lime);
      z-index: 1;
    }

    .sup-figure .estd {
      position: absolute;
      z-index: 3;
      left: -26px;
      bottom: 34px;
      background: var(--navy);
      color: #fff;
      padding: 20px 24px;
      border-radius: 6px;
      box-shadow: var(--shadow);
      text-align: center;
    }

    .sup-figure .estd b {
      font-family: 'Cormorant Garamond';
      font-size: 2.4rem;
      color: var(--lime);
      display: block;
      line-height: 1;
    }

    .sup-figure .estd span {
      font-family: 'Poppins';
      font-size: .6rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .78);
    }

    .looms {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 32px;
    }

    .loom {
      background: var(--paper-2);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 22px 22px;
      transition: transform .45s var(--ease), box-shadow .45s var(--ease), border-color .45s;
    }

    .loom:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow);
      border-color: var(--lime);
    }

    .loom .ic {
      width: 30px;
      height: 30px;
      color: var(--lime-deep);
      margin-bottom: 12px;
    }

    .loom h4 {
      font-size: 1.3rem;
      color: var(--navy);
    }

    .loom span {
      font-family: 'Poppins';
      font-size: .82rem;
      color: var(--muted);
      display: block;
      margin-top: 4px;
    }

    /* ---------- PRODUCT RIBBON ---------- */
    .ribbon {
      background: var(--navy);
      color: #fff;
    }

    .ribbon .wrap {
      padding-top: 64px;
      padding-bottom: 64px;
    }

    .ribbon-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 30px;
      flex-wrap: wrap;
      margin-bottom: 34px;
    }

    .ribbon-head h2 {
      font-size: clamp(1.8rem, 3.4vw, 2.6rem);
      color: #fff;
    }

    .ribbon-head h2 em {
      font-style: italic;
      color: var(--lime);
    }

    .ribbon-head p {
      font-family: 'Poppins';
      font-size: .92rem;
      color: rgba(255, 255, 255, .7);
      max-width: 360px;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .chip {
      font-family: 'Poppins';
      font-size: .84rem;
      font-weight: 300;
      letter-spacing: .02em;
      color: #eef3e3;
      border: 1px solid rgba(255, 255, 255, .2);
      padding: 10px 18px;
      border-radius: 40px;
      transition: .4s var(--ease);
    }

    .chip:hover {
      background: var(--lime);
      color: var(--navy);
      border-color: var(--lime);
      transform: translateY(-3px);
    }

    .chip b {
      color: var(--lime);
      font-weight: 600;
    }

    .chip:hover b {
      color: var(--navy);
    }

    /* ---------- OVERVIEW ---------- */
    .overview {
      background: linear-gradient(180deg, var(--paper) 0%, var(--paper-2) 100%);
    }

    .ov-grid {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 74px;
      align-items: center;
    }

    .ov-figure {
      position: relative;
    }

    .ov-figure img {
      border-radius: 6px;
      box-shadow: var(--shadow);
    }

    .ov-figure .ring {
      position: absolute;
      inset: -14px;
      border: 1px solid rgba(194, 162, 78, .45);
      border-radius: 8px;
      pointer-events: none;
    }

    /* ---------- QUALITY PROCESS ---------- */
    .quality {
      background: var(--navy);
      color: #fff;
    }

    .q-head {
      text-align: center;
      max-width: 680px;
      margin: 0 auto 64px;
    }

    .q-head h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      color: #fff;
      margin-top: 16px;
    }

    .q-head h2 em {
      font-style: italic;
      color: var(--lime);
    }

    .q-head p {
      font-family: 'Poppins';
      color: rgba(255, 255, 255, .74);
      font-size: 1rem;
      margin-top: 18px;
    }

    .q-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 26px;
    }

    .q-step {
      position: relative;
      padding: 34px 30px;
      border: 1px solid rgba(255, 255, 255, .14);
      border-radius: 8px;
      background: rgba(255, 255, 255, .03);
      transition: transform .5s var(--ease), background .5s var(--ease), border-color .5s;
    }

    .q-step:hover {
      transform: translateY(-8px);
      background: rgba(168, 210, 66, .08);
      border-color: var(--lime);
    }

    .q-step .num {
      font-family: 'Cormorant Garamond';
      font-size: 3.4rem;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
      font-style: italic;
    }

    .q-step h3 {
      font-size: 1.55rem;
      color: #fff;
      margin: 10px 0 10px;
    }

    .q-step p {
      font-family: 'Poppins';
      font-size: .9rem;
      color: rgba(255, 255, 255, .72);
    }

    .q-traits {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      margin-top: 54px;
    }

    .trait {
      font-family: 'Poppins';
      font-size: .82rem;
      letter-spacing: .04em;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 18px;
      border: 1px solid rgba(255, 255, 255, .16);
      border-radius: 40px;
    }

    .trait svg {
      width: 15px;
      height: 15px;
      color: var(--lime);
    }

    /* ---------- MISSION ---------- */
    .mission {
      background: var(--paper);
    }

    .mission .wrap {
      max-width: 1000px;
      text-align: center;
    }

    .mission .mk {
      font-family: 'Cormorant Garamond';
      font-size: 5rem;
      color: var(--lime);
      line-height: .4;
      display: block;
      height: 42px;
    }

    .mission blockquote {
      font-family: 'Cormorant Garamond';
      font-weight: 500;
      font-size: clamp(1.7rem, 3.4vw, 2.7rem);
      color: var(--navy);
      line-height: 1.32;
      margin: 0;
      font-style: italic;
    }

    .mission blockquote em {
      color: var(--gold);
      font-style: italic;
    }

    .mission .by {
      font-family: 'Poppins';
      font-size: .78rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 28px;
    }

    /* ---------- CTA BANNER ---------- */
    .cta-banner {
      position: relative;
      padding: 96px 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      background: var(--navy);
    }

    .cta-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1.6s var(--ease);
    }

    .cta-slide.active {
      opacity: 1;
    }

    .cta-slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .cta-banner::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 2;
      background: linear-gradient(rgba(12, 28, 46, .82), rgba(12, 28, 46, .78));
    }

    .cta-content {
      position: relative;
      z-index: 3;
      color: #fff;
      max-width: 780px;
      padding: 0 24px;
    }

    .cta-content h2 {
      font-size: clamp(2rem, 4.4vw, 3.4rem);
      margin: 18px 0 26px;
    }

    .cta-content h2 em {
      font-style: italic;
      color: var(--lime);
    }

    /* ---------- FOOTER ---------- */
    footer {
      background: var(--navy);
      color: rgba(255, 255, 255, .72);
      padding: 80px 0 0;
      position: relative;
      overflow: hidden;
    }

    footer::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
